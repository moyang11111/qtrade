# Environment Configuration for QTrade
# Copy this file to .env and fill in your values

# =============================================================================
# General Settings
# =============================================================================
QTRADE_ENV=production
QTRADE_LOG_LEVEL=INFO
QTRADE_DATA_DIR=/app/data
QTRADE_CACHE_DIR=/app/data/cache

# =============================================================================
# Data Source Configuration
# =============================================================================
# Primary data source: pytdx, akshare, or csv
QTRADE_DATA_SOURCE=pytdx

# Fallback data sources (comma-separated)
QTRADE_DATA_FALLBACK=akshare

# =============================================================================
# Database Configuration (Optional)
# =============================================================================
# PostgreSQL connection
DATABASE_URL=postgresql://qtrade:qtrade_secret@postgres:5432/qtrade

# Redis connection
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Broker API Configuration (For Live Trading)
# =============================================================================
# Alpaca API
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Interactive Brokers (if using)
# IB_HOST=127.0.0.1
# IB_PORT=7497
# IB_CLIENT_ID=1

# =============================================================================
# Alert Configuration
# =============================================================================
# Email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=your_email@gmail.com
ALERT_EMAIL_TO=your_email@gmail.com,another_email@gmail.com

# Slack webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# WeChat Work webhook
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# =============================================================================
# Risk Management
# =============================================================================
# Maximum drawdown percentage before circuit breaker
MAX_DRAWDOWN_PCT=10.0

# Maximum daily loss percentage
MAX_DAILY_LOSS_PCT=5.0

# Maximum position size as percentage of portfolio
MAX_POSITION_PCT=20.0

# Maximum slippage percentage
MAX_SLIPPAGE_PCT=1.0

# Maximum orders per minute
MAX_ORDERS_PER_MINUTE=10

# =============================================================================
# API Server Configuration
# =============================================================================
QTRADE_API_HOST=0.0.0.0
QTRADE_API_PORT=8000
QTRADE_API_WORKERS=2

# API authentication (optional)
# QTRADE_API_KEY=your_api_key
# QTRADE_API_SECRET=your_api_secret

# =============================================================================
# Web Dashboard Configuration
# =============================================================================
QTRADE_API_URL=http://api:8000

# =============================================================================
# Machine Learning Configuration
# =============================================================================
# Model registry path
MODEL_REGISTRY_PATH=/app/models

# MLflow tracking (optional)
# MLFLOW_TRACKING_URI=http://mlflow:5000

# =============================================================================
# QuantStats Configuration
# =============================================================================
# Benchmark symbol for performance comparison
QUANTSTATS_BENCHMARK=000300

# Risk-free rate for Sharpe ratio calculation
QUANTSTATS_RISK_FREE_RATE=0.03
